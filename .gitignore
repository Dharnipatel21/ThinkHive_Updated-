cat > .gitignore << 'EOF'
# Environment files
.env
backend/.env
frontend/.env
**/.env

# Python
__pycache__/
**/__pycache__/
*.pyc
venv/
backend/venv/

# Node
node_modules/
frontend/node_modules/
frontend/dist/

# Logs
*.log
backend-runtime*.log
frontend-runtime*.log

# OS/editor
.DS_Store
.vscode/
EOF